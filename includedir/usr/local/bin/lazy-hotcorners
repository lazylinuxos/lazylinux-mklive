from Xlib import display
from Xlib.ext.xtest import fake_input
from Xlib import X
from subprocess import Popen, PIPE, STDOUT
import sys, time, os, configparser, re
import argparse

check_intervall = 0.2

ap = argparse.ArgumentParser(description="Hotcorners")
ap.add_argument("-k", "--kill", help="attempt to kill any running instances",
                action="store_true")
ap.add_argument("-d", "--daemon", help="run daemon and listen for cursor triggers",
                action="store_true")
opts = ap.parse_args(sys.argv[1:])

# Get screen dimensions
p = Popen(['xdotool','getdisplaygeometry'], stdout=PIPE, stderr=STDOUT)
Dimensions = p.communicate()[0].decode('utf-8').strip().split(' ')
width = int(Dimensions[0])
height = int(Dimensions[1])
hw = width // 2
rt = width - 1
bt = height - 1

if opts.kill:
    print("Attempting to kill any running instances...")
    os.system('pkill -9 -f lazy-hotcorners')
    exit()

elif opts.daemon:
    Config = configparser.ConfigParser()
    cfgdir = os.path.join(os.getenv("HOME"), ".config", "lazy-hotcorners")
    rcfile = os.path.join(cfgdir, "lazy-hotcornersrc")
    bounce = 40
    disp = display.Display()
    root = disp.screen().root

    def mousepos():
        data = root.query_pointer()._data
        return data["root_x"], data["root_y"], data["mask"]

    def mousemove(x, y):
        fake_input(disp, X.MotionNotify, x=int(x), y=int(y))
        disp.sync()

    try:
        cfgfile = open(rcfile)
        cfgfile.close()
    except IOError:
        if not os.path.exists(cfgdir):
            os.makedirs(cfgdir)
        with open(rcfile, 'w') as cfgfile:
            Config.add_section('Hot Corners')
            Config.set('Hot Corners','top_left_corner_command', 'gmrun')
            Config.set('Hot Corners','top_right_corner_command', '')
            Config.set('Hot Corners','bottom_left_corner_command', '')
            Config.set('Hot Corners','bottom_right_corner_command', '')
            Config.write(cfgfile)

    while True:
        Config.read(rcfile)
        time.sleep(check_intervall)
        pos = mousepos()

        if pos[0] == 0 and pos[1] == 0:
            cmd = Config.get('Hot Corners','top_left_corner_command')
            if cmd:
                time.sleep(0.2)
                pos = mousepos()
                if pos[0] == 0 and pos[1] == 0:
                    mousemove(pos[0] + bounce, pos[1] + bounce)
                    os.system(f'({cmd}) &')
                    mousemove(pos[0] + bounce, pos[1] + bounce)
                    time.sleep(2)

        elif pos[0] == rt and pos[1] == 0:
            cmd = Config.get('Hot Corners','top_right_corner_command')
            if cmd:
                time.sleep(0.2)
                pos = mousepos()
                if pos[0] == rt and pos[1] == 0:
                    mousemove(pos[0] - bounce, pos[1] + bounce)
                    os.system(f'({cmd}) &')
                    mousemove(pos[0] - bounce, pos[1] + bounce)
                    time.sleep(2)

        elif pos[0] == 0 and pos[1] == bt:
            cmd = Config.get('Hot Corners','bottom_left_corner_command')
            if cmd:
                time.sleep(0.2)
                pos = mousepos()
                if pos[0] == 0 and pos[1] == bt:
                    mousemove(pos[0] + bounce, pos[1] - bounce)
                    os.system(f'({cmd}) &')
                    mousemove(pos[0] + bounce, pos[1] - bounce)
                    time.sleep(2)

        elif pos[0] == rt and pos[1] == bt:
            cmd = Config.get('Hot Corners','bottom_right_corner_command')
            if cmd:
                time.sleep(0.2)
                pos = mousepos()
                if pos[0] == rt and pos[1] == bt:
                    mousemove(pos[0] - bounce, pos[1] - bounce)
                    os.system(f'({cmd}) &')
                    mousemove(pos[0] - bounce, pos[1] - bounce)
                    time.sleep(2)
